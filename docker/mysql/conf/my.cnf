[mysqld]
# Memory — tuned for low-traffic RAG assistant on a constrained server
innodb_buffer_pool_size     = 256M   # main memory user; default 128M, prod usually 70% of RAM
innodb_log_buffer_size      = 16M    # write buffer before flush to disk
innodb_log_file_size        = 64M    # redo log; larger = fewer IOPs, more recovery time

# Connections — interview bot has very low concurrency
max_connections             = 50     # default 151; each idle connection costs ~1MB
thread_cache_size           = 8

# Table/query cache
table_open_cache            = 400    # default 4000; overkill for this schema size
tmp_table_size              = 32M
max_heap_table_size         = 32M

# Performance schema — disable to save ~300-400MB RAM
performance_schema          = OFF

# Charset
character-set-server        = utf8mb4
collation-server            = utf8mb4_unicode_ci
